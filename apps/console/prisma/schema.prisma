generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 農薬基本情報（登録基本部）
model Pesticide {
  id                              Int      @id @default(autoincrement())
  registrationNumber              String   @unique @map("registration_number")
  pesticideType                   String   @map("pesticide_type")
  pesticideName                   String   @map("pesticide_name")
  companyName                     String   @map("company_name")
  activeIngredient                String   @map("active_ingredient")
  activeIngredientForTotalCount   String   @map("active_ingredient_for_total_count")
  concentration                   String   @map("concentration")
  mixCount                        Int      @map("mix_count")
  usage                           String   @map("usage")
  formulation                     String   @map("formulation")
  registrationDate                DateTime? @map("registration_date")

  applications PesticideApplication[]

  @@map("pesticides")
}

/// 農薬適用情報（登録適用部）
model PesticideApplication {
  id                      Int      @id @default(autoincrement())
  registrationNumber      String   @map("registration_number")
  usage                   String   @map("usage")
  pesticideType           String   @map("pesticide_type")
  pesticideName           String   @map("pesticide_name")
  companyAbbreviation     String   @map("company_abbreviation")
  cropName                String   @map("crop_name")
  applicationPlace        String?  @map("application_place")
  pestName                String   @map("pest_name")
  purpose                 String?  @map("purpose")
  dilutionRate            String   @map("dilution_rate")
  sprayVolume             String?  @map("spray_volume")
  usagePeriod             String   @map("usage_period")
  maxCount                String   @map("max_count")
  usageMethod             String   @map("usage_method")
  fumigationTime          String?  @map("fumigation_time")
  fumigationTemperature   String?  @map("fumigation_temperature")
  applicationSoil         String?  @map("application_soil")
  applicationArea         String?  @map("application_area")
  applicationPesticideName String? @map("application_pesticide_name")
  mixCount                Int      @map("mix_count")
  totalMaxCount1          String?  @map("total_max_count_1")
  totalMaxCount2          String?  @map("total_max_count_2")
  totalMaxCount3          String?  @map("total_max_count_3")
  totalMaxCount4          String?  @map("total_max_count_4")
  totalMaxCount5          String?  @map("total_max_count_5")

  pesticide Pesticide @relation(fields: [registrationNumber], references: [registrationNumber])

  @@index([cropName])
  @@index([registrationNumber])
  @@map("pesticide_applications")
}
