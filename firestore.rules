rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 送られてきたリクエストのデータ
    function requestData() {
      return request.resource.data;
    }

    // 既存のドキュメントのデータ
    function resourceData() {
      return resource.data;
    }

    // ログイン済かどうか
    function isSignedIn() {
      return request.auth.uid != null;
    }

    // ユーザーIDが一致するかどうか
    function isUser(userId) {
      return request.auth.uid == userId;
    }

    // User のスキーマバリデーション
    function isValidUserSchema(data) {
      return data.size() == 3
        && 'createdAt' in data && data.createdAt is timestamp
        && 'phoneNumber' in data && data.phoneNumber is string
        && 'updatedAt' in data && data.updatedAt is timestamp;
    }

    // Field のスキーマバリデーション
    function isValidFieldSchema(data) {
      return data.size() == 4
        && 'createdAt' in data && data.createdAt is timestamp
        && 'name' in data && data.name is string
        && 'updatedAt' in data && data.updatedAt is timestamp
        && 'userId' in data && data.userId is string;
    }

    // Spray のスキーマバリデーション
    function isValidSpraySchema(data) {
      return data.size() == 13
        && 'createdAt' in data && data.createdAt is timestamp
        && 'dilutionRate' in data && data.dilutionRate is number
        && 'fieldId' in data && data.fieldId is string
        && 'fieldName' in data && data.fieldName is string
        && 'note' in data && data.note is string
        && 'pesticideAmount' in data && data.pesticideAmount is number
        && 'pesticideName' in data && data.pesticideName is string
        && 'pesticideUnit' in data && data.pesticideUnit is string
        && 'registrationNumber' in data && data.registrationNumber is string
        && 'sprayAmount' in data && data.sprayAmount is number
        && 'sprayedAt' in data && data.sprayedAt is timestamp
        && 'updatedAt' in data && data.updatedAt is timestamp
        && 'userId' in data && data.userId is string;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && isUser(userId);
      allow create: if isSignedIn() && isUser(userId) && isValidUserSchema(requestData());
      allow update: if isSignedIn() && isUser(userId) && isValidUserSchema(requestData());
    }

    match /fields/{fieldId} {
      allow read: if isSignedIn() && isUser(resourceData().userId);
      allow create: if isSignedIn() && isUser(requestData().userId) && isValidFieldSchema(requestData());
      allow update: if isSignedIn() && isUser(resourceData().userId) && isValidFieldSchema(requestData());
      allow delete: if isSignedIn() && isUser(resourceData().userId);
    }

    match /sprays/{sprayId} {
      allow read: if isSignedIn() && isUser(resourceData().userId);
      allow create: if isSignedIn() && isUser(requestData().userId) && isValidSpraySchema(requestData());
      allow update: if isSignedIn() && isUser(resourceData().userId) && isValidSpraySchema(requestData());
      allow delete: if isSignedIn() && isUser(resourceData().userId);
    }

    // 農薬マスターデータ（Cloud Functionsからのみ書き込み、認証済みユーザーは読み取りのみ）
    match /pesticides/{pesticideId} {
      allow read: if isSignedIn();
    }

    // 作物名→農薬の逆引きインデックス（Cloud Functionsからのみ書き込み、認証済みユーザーは読み取りのみ）
    match /cropIndex/{cropName} {
      allow read: if isSignedIn();
    }
  }
}
